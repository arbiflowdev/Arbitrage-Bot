# =============================================================================
# Digital Goods Arbitrage Platform - Backend (Milestone 1)
# Copy this file to `.env` and adjust the values for your environment.
# =============================================================================

# --- Application -------------------------------------------------------------
APP_NAME="Digital Goods Arbitrage Platform"
APP_ENV=development          # development | staging | production | test
APP_VERSION=0.1.0
API_V1_PREFIX=/api
DEBUG=false
HOST=0.0.0.0
PORT=8000

# --- Database ----------------------------------------------------------------
# Async SQLAlchemy URL (asyncpg driver).
DATABASE_URL="postgresql://neondb_owner:npg_1FoQV4Wyhcge@ep-misty-frost-aqlzncs7-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Used only by docker-compose to provision the postgres container.
POSTGRES_USER=arbitrage
POSTGRES_PASSWORD=arbitrage
POSTGRES_DB=arbitrage
POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------------
# For local dev (running uvicorn outside Docker), point at localhost.
# Inside docker-compose the service name `redis` is used instead.
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# --- Marketplace integrations (Milestone 2) ----------------------------------
# mock = run with no real API keys (default); live = call real marketplace APIs.
MARKETPLACE_MODE=mock
KINGUIN_API_BASE_URL=https://gateway.kinguin.net/esa/api
G2G_API_BASE_URL=https://open.g2g.com
ENEBA_API_BASE_URL=https://api.eneba.com
ENEBA_OAUTH_TOKEN_URL=https://user.eneba.com/oauth/token
KINGUIN_RATE_LIMIT_PER_MINUTE=60
G2G_RATE_LIMIT_PER_MINUTE=60
ENEBA_RATE_LIMIT_PER_MINUTE=120
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_SECONDS=0.5
# --- Live API keys -----------------------------------------------------------
# The only place credentials live. Paste keys here + set MARKETPLACE_MODE=live
# to go live. Leave blank to keep running in mock mode.
KINGUIN_API_KEY=
KINGUIN_API_SECRET=
G2G_API_KEY=
G2G_API_SECRET=
# Eneba uses OAuth 2.0 (GraphQL API). Onboarding from Eneba gives you a client
# id plus an authorization id + secret; ENEBA_WEBHOOK_SECRET is the Authorization
# header value you register for inbound callbacks. Paste them in when ready.
ENEBA_CLIENT_ID=
ENEBA_AUTH_ID=
ENEBA_API_SECRET=
ENEBA_WEBHOOK_SECRET=

# --- Arbitrage / dynamic pricing engine (Milestone 3) -----------------------
BASE_CURRENCY=EUR
PRICING_SCAN_INTERVAL_SECONDS=60
PRICING_ENGINE_ENABLED=true
# Preview mode: compute + record decisions but never push a price change.
# Set false for fully-automated repricing (recommended once live keys are in).
PRICING_DRY_RUN=false
# Strategy thresholds — the "financial red line" plus the undercut tactics.
PRICING_UNDERCUT_AMOUNT=0.01
PRICING_MIN_PROFIT_ABSOLUTE=0.30
PRICING_MIN_PROFIT_MARGIN_PERCENT=5
PRICING_ANOMALY_DROP=0.50
PRICING_FALLBACK_RANK=3
# FX: free exchange-rate feed (USD/EUR etc.) + intra-day safety buffer.
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest
EXCHANGE_RATE_TTL_SECONDS=3600
CURRENCY_BUFFER_PERCENT=1
# Composite marketplace fees: percentage fee + fixed fee per transaction.
KINGUIN_FEE_PERCENT=11
KINGUIN_FEE_FIXED=0.35
G2G_FEE_PERCENT=9.9
G2G_FEE_FIXED=0
ENEBA_FEE_PERCENT=12
ENEBA_FEE_FIXED=0.30
# Withdrawal / payout buffers (global defaults; a fee_structures row overrides).
MARKETPLACE_WITHDRAWAL_PERCENT=0
MARKETPLACE_WITHDRAWAL_FIXED=0

# --- Hybrid inventory & JIT fulfillment (Milestone 4) -----------------------
# Master on/off for the fulfillment sweep + order-poll workers.
FULFILLMENT_ENABLED=true
# How often the safety-net poll pulls new orders per provider (live mode only).
FULFILLMENT_POLL_INTERVAL_SECONDS=60
# Retry budget per order before it is marked FAILED, plus base retry backoff.
FULFILLMENT_MAX_ATTEMPTS=5
FULFILLMENT_RETRY_BACKOFF_SECONDS=30
# Allow buying stock just-in-time from the cheapest other marketplace.
JIT_ENABLED=true
# Safety cushion over the quoted source cost when checking wallet funds.
JIT_SOURCE_BUFFER_PERCENT=2
# Reject a JIT purchase if the wallet lacks funds (false = track only).
WALLET_ENFORCE=true

# --- Alerts & dashboard (Milestone 5) ---------------------------------------
# Master on/off for raising operational alerts.
ALERTS_ENABLED=true
# Raise a LOW_WALLET alert when a wallet's base-currency balance drops below this.
ALERT_LOW_WALLET_THRESHOLD=25

# --- JWT ---------------------------------------------------------------------
# IMPORTANT: replace with a long random secret in production.
JWT_SECRET=replace-me-with-a-long-random-secret-string-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS --------------------------------------------------------------------
# Comma-separated list or "*" for any origin.
CORS_ORIGINS=*

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=true

# --- Bootstrap admin (optional) ----------------------------------------------
# When both are set, an admin account is ensured at startup. Use this only
# for the very first deployment, then remove or rotate the password.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ArbAdmin!2026

# --- docker-compose ----------------------------------------------------------
BACKEND_PORT=8000
