
# --- Application -------------------------------------------------------------
APP_NAME="Digital Goods Arbitrage Platform"
APP_ENV=development         
APP_VERSION=0.1.0
API_V1_PREFIX=/api
DEBUG=false
HOST=0.0.0.0
PORT=8000
# --- Database ----------------------------------------------------------------
DATABASE_URL=
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

POSTGRES_USER=arbitrage
POSTGRES_PASSWORD=arbitrage
POSTGRES_DB=arbitrage
POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# --- JWT ---------------------------------------------------------------------
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS --------------------------------------------------------------------
CORS_ORIGINS=*

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=true


# --- docker-compose ----------------------------------------------------------
BACKEND_PORT=8000
