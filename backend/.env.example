
# --- Application -------------------------------------------------------------
APP_NAME="Digital Goods Arbitrage Platform"
APP_ENV=development         
APP_VERSION=0.1.0
API_V1_PREFIX=/api
DEBUG=false
HOST=0.0.0.0
PORT=8000
# --- Database ----------------------------------------------------------------
DATABASE_URL=
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

POSTGRES_USER=arbitrage
POSTGRES_PASSWORD=arbitrage
POSTGRES_DB=arbitrage
POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# --- Marketplace integrations ----------------------------------
# mock = run with no API keys (default); live = call the real marketplace APIs.
MARKETPLACE_MODE=mock
KINGUIN_API_BASE_URL=https://gateway.kinguin.net/esa/api
G2G_API_BASE_URL=https://open.g2g.com
ENEBA_API_BASE_URL=https://api.eneba.com
ENEBA_OAUTH_TOKEN_URL=https://user.eneba.com/oauth/token
KINGUIN_RATE_LIMIT_PER_MINUTE=60
G2G_RATE_LIMIT_PER_MINUTE=60
ENEBA_RATE_LIMIT_PER_MINUTE=120
# Shared outbound HTTP behaviour.
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_SECONDS=0.5
# --- Live API keys ------------------------------------------------
# The ONLY place credentials live. Paste your keys here and set
# MARKETPLACE_MODE=live above to go live; leave blank to stay in mock mode.
# *_API_SECRET is the provider's webhook/HMAC signing secret.
KINGUIN_API_KEY=
KINGUIN_API_SECRET=
G2G_API_KEY=
G2G_API_SECRET=
# Eneba uses OAuth 2.0 (GraphQL API), so it needs more than one value:
#   ENEBA_CLIENT_ID      - your client id from Eneba onboarding
#   ENEBA_AUTH_ID        - authorization id provided by your Eneba rep
#   ENEBA_API_SECRET     - authorization secret provided by your Eneba rep
#   ENEBA_WEBHOOK_SECRET - Authorization header value you register for callbacks
# Leave blank to keep Eneba in mock mode.
ENEBA_CLIENT_ID=
ENEBA_AUTH_ID=
ENEBA_API_SECRET=
ENEBA_WEBHOOK_SECRET=

# --- Arbitrage / dynamic pricing engine-----------------------
BASE_CURRENCY=EUR
PRICING_SCAN_INTERVAL_SECONDS=60
PRICING_ENGINE_ENABLED=true
# Set false for fully-automated repricing (recommended once live keys are in).
PRICING_DRY_RUN=false
# Strategy thresholds — the "financial red line" plus the undercut tactics.
PRICING_UNDERCUT_AMOUNT=0.01
PRICING_MIN_PROFIT_ABSOLUTE=0.30
PRICING_MIN_PROFIT_MARGIN_PERCENT=5
PRICING_ANOMALY_DROP=0.50
PRICING_FALLBACK_RANK=3
# FX: free exchange-rate feed (USD/EUR etc.) + intra-day safety buffer.
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest
EXCHANGE_RATE_TTL_SECONDS=3600
CURRENCY_BUFFER_PERCENT=1
# Composite marketplace fees: percentage fee + fixed fee per transaction.
KINGUIN_FEE_PERCENT=11
KINGUIN_FEE_FIXED=0.35
G2G_FEE_PERCENT=9.9
G2G_FEE_FIXED=0
ENEBA_FEE_PERCENT=12
ENEBA_FEE_FIXED=0.30
# Withdrawal / payout buffers (global defaults; a fee_structures row overrides).
MARKETPLACE_WITHDRAWAL_PERCENT=0
MARKETPLACE_WITHDRAWAL_FIXED=0

# --- JWT ---------------------------------------------------------------------
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS --------------------------------------------------------------------
CORS_ORIGINS=*

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=true


# --- docker-compose ----------------------------------------------------------
BACKEND_PORT=8000
