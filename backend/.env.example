
# --- Application -------------------------------------------------------------
APP_NAME="Digital Goods Arbitrage Platform"
APP_ENV=development         
APP_VERSION=0.1.0
API_V1_PREFIX=/api
DEBUG=false
HOST=0.0.0.0
PORT=8000
# --- Database ----------------------------------------------------------------
DATABASE_URL=
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

POSTGRES_USER=arbitrage
POSTGRES_PASSWORD=arbitrage
POSTGRES_DB=arbitrage
POSTGRES_PORT=5432

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# --- Marketplace integrations ----------------------------------
# mock = run with no API keys (default); live = call the real marketplace APIs.
MARKETPLACE_MODE=mock
KINGUIN_API_BASE_URL=https://gateway.kinguin.net/esa/api
G2G_API_BASE_URL=https://open.g2g.com
KINGUIN_RATE_LIMIT_PER_MINUTE=60
G2G_RATE_LIMIT_PER_MINUTE=60
# Shared outbound HTTP behaviour.
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_SECONDS=0.5
# --- Live API keys ------------------------------------------------
# The ONLY place credentials live. Paste your keys here and set
# MARKETPLACE_MODE=live above to go live; leave blank to stay in mock mode.
# *_API_SECRET is the provider's webhook/HMAC signing secret.
KINGUIN_API_KEY=
KINGUIN_API_SECRET=
G2G_API_KEY=
G2G_API_SECRET=

# --- JWT ---------------------------------------------------------------------
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS --------------------------------------------------------------------
CORS_ORIGINS=*

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=true


# --- docker-compose ----------------------------------------------------------
BACKEND_PORT=8000
