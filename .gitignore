# =============================================================================
# Digital Goods Arbitrage Platform — root .gitignore
#
# Anything matched here will NOT be pushed to GitHub. Secrets, virtual
# environments, build artifacts, caches, and IDE/OS files are excluded.
# `.env.example` (template, no secrets) is explicitly kept tracked.
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & environment files  (CRITICAL — never commit real credentials)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
secrets/
credentials/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
nosetests.xml

# Linters / type checkers
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Local databases / dumps
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.dump
*.sql.gz
pgdata/
postgres_data/
redis_data/

# -----------------------------------------------------------------------------
# Node / Frontend
# -----------------------------------------------------------------------------
node_modules/
.pnp/
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.next/
.nuxt/
.turbo/
out/
.parcel-cache/
.svelte-kit/
.vite/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml
*.pid

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# IDEs / editors
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.iml
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# OS noise
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.claude/
.claude.json
.claude.local.json
*.claude-session*

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.orig
*.rej
.cache/
Arbitrage Platform Srs.docx
Arbitrage_Platform_Milestone_Plan.docx
*.docx