# =============================================================================
# Production environment template for the VPS deployment.
#
#   cp env.example .env      # then fill in the real values below
#
# deploy/.env is gitignored — it is the ONLY place secrets live. Never commit it.
# Anything left blank simply keeps that feature/provider dormant.
# =============================================================================

# --- Public hostname / TLS ---------------------------------------------------
# Your domain (gets free auto-HTTPS), e.g. app.yourdomain.com
# Interim before you have a domain: set DOMAIN=:80 to serve plain HTTP on the IP.
DOMAIN=app.example.com

# --- Core app ----------------------------------------------------------------
APP_ENV=production
MARKETPLACE_MODE=live

# Postgres on Neon — async driver + TLS. Paste your Neon connection string.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Lock the dashboard/API to its own origin. Use https://<DOMAIN> in production,
# or http://<server-ip> while running http-only.
CORS_ORIGINS=https://app.example.com

# Long random secret (min 32 chars). Generate with:  openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32

# First admin login — created on startup. Change the password after first login.
BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password

# --- Outbound IP -------------------------------------------------------------
# Leave BOTH blank: the VPS's own public IP is the static IP you whitelist with
# the marketplaces, so no third-party proxy is needed.
OUTBOUND_PROXY_URL=
QUOTAGUARDSTATIC_URL=

# --- Marketplace credentials -------------------------------------------------
# A provider activates automatically as soon as its keys are present.
KINGUIN_API_KEY=
KINGUIN_API_SECRET=
G2G_API_KEY=
G2G_API_SECRET=
G2G_USER_ID=
ENEBA_CLIENT_ID=
ENEBA_AUTH_ID=
ENEBA_API_SECRET=
ENEBA_WEBHOOK_SECRET=

# --- Optional tuning (sensible defaults already baked into the app) ----------
# Uncomment to override. See backend/.env.example for the full list.
# PRICING_DRY_RUN=false
# PRICING_SCAN_INTERVAL_SECONDS=60
# FULFILLMENT_ENABLED=true
# ALERT_LOW_WALLET_THRESHOLD=25
